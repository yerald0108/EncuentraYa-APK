{
  "expo": {
    "name": "EcuentraYa",
    "slug": "encuentraya",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.encuentraya.app"
    },
    "android": {
      "package": "com.encuentraya.app"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "EcuentraYa necesita tu ubicación para mostrarte mipymes cercanas."
        }
      ]
    ],
    "scheme": "encuentraya",
    "experiments": {
      "typedRoutes": true
    }
  }
}