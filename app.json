{
  "expo": {
    "name": "EcuentraYa",
    "slug": "encuentraya",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.encuentraya.app"
    },
    "android": {
      "package": "com.encuentraya.app",
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "EcuentraYa necesita tu ubicación para mostrarte mipymes cercanas."
        }
      ]
    ],
    "scheme": "encuentraya",
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "3119ccee-56be-4280-bad1-373c0e52d215"
      }
    }
  }
}
